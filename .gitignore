# ============================================================================
# Secrets — JAMAIS commit en clair
# ============================================================================
#
# IMPORTANT : .gitignore ne protege QUE Git. Comme ce repo vit dans
# G:\Mon disque\ (Google Drive sync), les .env sont uploades vers Google
# meme s'ils ne sont pas commit. Solution :
#   - Garder les vrais .env hors de Drive : $env:USERPROFILE\.hub-secrets\
#   - Creer un symlink dans le repo qui pointe vers le vrai fichier
#   - Voir : hub-deploy/scripts/migrate-env-out-of-drive.ps1
#           hub-deploy/docs/SECRETS-OUT-OF-DRIVE.md
#

# .env (contient mots de passe Postgres + tokens)
.env
.env.*
!.env.example

# Vault age + sops
# On bloque tous les .yaml dans secrets/, et on autorise UNIQUEMENT *.enc.yaml.
secrets/*.yaml
!secrets/*.enc.yaml

# Clés brutes
secrets/*.key
secrets/*.txt
*.pem
*.key

# Cloudflare credentials (UUID-based filename)
cloudflared/*.json
!cloudflared/config.example.yml

# ============================================================================
# Volumes Docker locaux
# ============================================================================
volumes/
data/

# ============================================================================
# Backups
# ============================================================================
backup/restic-cache/
backup/staging/

# ============================================================================
# Logs
# ============================================================================
*.log
logs/

# ============================================================================
# OS
# ============================================================================
.DS_Store
Thumbs.db

# ============================================================================
# IDE
# ============================================================================
.vscode/
.idea/

# Vault age (chiffré OK mais on évite le commit accidentel)
*.age
*.enc
