# Hub Deploy environment
# Copie en .env et remplis avec tes valeurs

# === Database ===
POSTGRES_USER=hub
POSTGRES_PASSWORD=changeme-postgres-password
POSTGRES_DB=hubdb

# === Hub-core ===
APP_ENV=dev
LOG_LEVEL=INFO
SECRET_KEY=changeme-changeme-changeme-changeme

# === Ollama ===
OLLAMA_MODEL=qwen2.5:14b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# === Google OAuth 2.0 (Phase 3+) ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/v1/oauth/callback

# === Frontend URL ===
FRONTEND_URL=http://localhost:3000

# === Cloudflare Tunnel (Phase 0+) ===
# Récupéré dans Cloudflare Zero Trust dashboard après création du tunnel.
# La valeur "ci-placeholder" est utilisée pour la validation CI uniquement —
# remplace par le vrai token quand tu configures le tunnel.
CLOUDFLARE_TUNNEL_TOKEN=ci-placeholder

# === DuckDNS (Phase 0+) ===
# Récupéré sur https://www.duckdns.org après création du compte
DUCKDNS_TOKEN=
DUCKDNS_DOMAIN=marc-hub

# === Cloudflare Access (auth, Phase 0+) ===
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUDIENCE=

# === Restic backup (Phase 0+) ===
# Mot de passe FORT pour chiffrer le coffre restic (perdu = backup perdu)
RESTIC_PASSWORD=
# Repo restic : ici on utilise OneDrive en local sync (gratuit)
RESTIC_REPOSITORY=C:\Users\dessin14\OneDrive\hub-backup
# Paths a backuper, separes par ;
BACKUP_PATHS=G:\Mon disque\PERSO & LOISIRS\AUTOMATISATION\Projets\Hub perso;C:\HubFrontend
